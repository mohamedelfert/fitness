{
  "$meta": {
    "name": "fitness-os-design-tokens",
    "version": "0.1.0",
    "source": "docs/UI_UX_SYSTEM.md",
    "note": "Source of truth. Edit here, then run `node build.mjs` to regenerate Tailwind/CSS/Flutter targets. Components must reference SEMANTIC tokens, never raw hex."
  },
  "color": {
    "dark": {
      "bg-base": "#0B0E11",
      "bg-surface": "#13171C",
      "bg-surface-raised": "#1B2128",
      "border-subtle": "#252C34",
      "text-primary": "#F5F7FA",
      "text-secondary": "#A8B2BD",
      "text-muted": "#6B7682",
      "brand-primary": "#00E5A0",
      "brand-primary-press": "#00C489",
      "accent-electric": "#4C8DFF",
      "feedback-success": "#3DDC84",
      "feedback-warning": "#FFB020",
      "feedback-danger": "#FF5C5C"
    },
    "light": {
      "bg-base": "#FFFFFF",
      "bg-surface": "#F6F8FA",
      "bg-surface-raised": "#FFFFFF",
      "border-subtle": "#E2E8F0",
      "text-primary": "#0B0E11",
      "text-secondary": "#475569",
      "text-muted": "#94A3B8",
      "brand-primary": "#00B888",
      "brand-primary-press": "#009E74",
      "accent-electric": "#2563EB",
      "feedback-success": "#16A34A",
      "feedback-warning": "#D97706",
      "feedback-danger": "#DC2626"
    },
    "data": {
      "1": "#00E5A0", "2": "#4C8DFF", "3": "#FFB020",
      "4": "#B57BFF", "5": "#FF7AB2", "6": "#5AD6D6"
    }
  },
  "font": {
    "family-latin": "Inter, system-ui, sans-serif",
    "family-arabic": "'IBM Plex Sans Arabic', 'Tajawal', sans-serif",
    "scale": {
      "display": { "size": 40, "line": 48, "weight": 600 },
      "h1": { "size": 28, "line": 36, "weight": 600 },
      "h2": { "size": 22, "line": 30, "weight": 600 },
      "h3": { "size": 18, "line": 26, "weight": 600 },
      "body": { "size": 16, "line": 24, "weight": 400 },
      "body-sm": { "size": 14, "line": 20, "weight": 400 },
      "caption": { "size": 12, "line": 16, "weight": 400 }
    }
  },
  "space": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40, "12": 48, "16": 64 },
  "radius": { "sm": 8, "md": 12, "lg": 16, "xl": 24, "full": 9999 },
  "motion": {
    "instant": { "ms": 100, "curve": "ease-out" },
    "quick": { "ms": 200, "curve": "ease-out" },
    "standard": { "ms": 300, "curve": "cubic-bezier(0.2,0,0,1)" },
    "expressive": { "ms": 450, "curve": "spring" }
  }
}
